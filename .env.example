VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_WOMPI_PUBLIC_KEY=pub_test_or_prod_xxxxxxxxxxxxxxxxxxxxx

# Supabase Edge Function secrets. Configure these in Supabase, never expose them as VITE_*.
WOMPI_INTEGRITY_KEY=your-wompi-integrity-secret
WOMPI_EVENTS_SECRET=your-wompi-events-secret   # Configurar en Wompi Dashboard > Eventos > Secreto de eventos
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
ALLOWED_ORIGIN=https://your-production-domain.com
